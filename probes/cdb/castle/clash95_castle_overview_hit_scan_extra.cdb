.echo === Clash95 castle overview hit-id scan probe ===
.echo CDB-only scan of the native overview surface for command hit id 0xF8
r @$t8=3
r @$t18=0
r @$t19=0

bp /1 0040B660 ".if ((poi(005202e4) != 0) & (@$t18 == 0)) { r @$t18=1; .printf \"CASTLEOV_HITSCAN_INVOKE_PLAYGAME castle_index=0 gd=%p surface=%p sz=(%d,%d)\n\", poi(005202e4), poi(005202e0), wo(poi(005202e0)), wo(poi(005202e0)+2); r esp=@esp-4; ed @esp 0040b660; r eax=0; r eip=00422180; }; gc"
bp 00422333 ".if (@$t18 != 0) { r @$t11=poi(00526a68); r @$t12=wo(@$t11); r @$t15=wo(@$t11+2); r @$t16=poi(@$t11+4); .printf \"CASTLEOV_HITSCAN_OVERVIEW_SURFACE surface=%p size=(%d,%d) base=%p search=full target=0xf8\n\", @$t11, @$t12, @$t15, @$t16; s -b @$t16 L0n307200 f8; .echo CASTLEOV_HITSCAN_DONE; q } .else { gc }"
