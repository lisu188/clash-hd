bp 00407E8F ".if (@$t14 != 0) { .if (@$t12 < 0n120) { .printf \"KEYSCROLL_DOWN seq=%d scroll=(%d,%d) map=(%d,%d)\\n\", @$t12, poi(poi(005202e4)+0n140008), poi(poi(005202e4)+0n140012), poi(poi(005202e4)+0n140000), poi(poi(005202e4)+0n140004); r @$t12 = @$t12 + 1; }; }; gc"
bp 00406FA0 ".if (@$t14 != 0) { .if (@$t13 < 0n180) { r @$t15 = poi(005202e4); r @$t16 = poi(@$t15+0n140000)-0n12; r @$t17 = poi(@$t15+0n140004)-0n9; r @$t18 = poi(@$t15+0n140000)-0n9; r @$t19 = poi(@$t15+0n140004)-0n7; .if (@$t16 < 0) { r @$t16 = 0; }; .if (@$t17 < 0) { r @$t17 = 0; }; .printf \"KEYSCROLL_REDRAW seq=%d scroll=(%d,%d) end12=(%d,%d) map=(%d,%d) max_hd=(%d,%d) max_old=(%d,%d)\\n\", @$t13, poi(@$t15+0n140008), poi(@$t15+0n140012), poi(@$t15+0n140008)+0n12, poi(@$t15+0n140012)+0n9, poi(@$t15+0n140000), poi(@$t15+0n140004), @$t16, @$t17, @$t18, @$t19; r @$t13 = @$t13 + 1; }; }; gc"

g
