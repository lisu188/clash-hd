bp 00444490 ".printf \"KEYSCROLL_LOADSAVE selected_arg=%d selected_global=%d accept=%d choice=%d gd=%p\\n\", @eax, poi(005441e0), poi(00544190), poi(00543d7c), poi(005202e4); gc"

bp 0040B660 ".if (poi(005202e4) != 0) { r @$t14 = 1; eb 005451c0 00; ed 00544d04 0; .printf \"KEYSCROLL_PLAYGAME gd=%p map=(%d,%d) scroll=(%d,%d) target_keys=(right,down)\\n\", poi(005202e4), poi(poi(005202e4)+0n140000), poi(poi(005202e4)+0n140004), poi(poi(005202e4)+0n140008), poi(poi(005202e4)+0n140012); } .else { .echo KEYSCROLL_PLAYGAME gd=00000000; }; gc"

bp 00407D20 ".if (@$t14 != 0) { ed 005202a0 0; ed 00545140 0; eb 00545204 00; eb 00545294 00; eb 00545297 00; eb 00545299 80; eb 0054529c 80; .if (@$t10 < 0n180) { r @$t15 = poi(005202e4); r @$t16 = poi(@$t15+0n140000)-0n12; r @$t17 = poi(@$t15+0n140004)-0n9; r @$t18 = poi(@$t15+0n140000)-0n9; r @$t19 = poi(@$t15+0n140004)-0n7; .if (@$t16 < 0) { r @$t16 = 0; }; .if (@$t17 < 0) { r @$t17 = 0; }; .printf \"KEYSCROLL_ENTRY seq=%d scroll=(%d,%d) map=(%d,%d) max_hd=(%d,%d) max_old=(%d,%d) keys right=%02x down=%02x timer=%d\\n\", @$t10, poi(@$t15+0n140008), poi(@$t15+0n140012), poi(@$t15+0n140000), poi(@$t15+0n140004), @$t16, @$t17, @$t18, @$t19, by(00545299), by(0054529c), poi(005202a0); r @$t10 = @$t10 + 1; }; }; gc"
