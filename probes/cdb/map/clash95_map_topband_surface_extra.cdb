.echo === Clash95 HD map top-band surface extra ===
.echo logs minimap globals and 800x600 top-right source/write samples under the surface-dump harness

bp 0040D3B6 ".if (poi(0052334c) != 0) { .printf \"MINIMAP_INIT left=%d top=%d width=%d height=%d right=%d bottom=%d backing=%p backing_sz=(%d,%d) scale=%d\\n\", wo(00523344), wo(00523346), wo(00523348), wo(0052334a), wo(00523344)+wo(00523348)-1, wo(00523346)+wo(0052334a)-1, poi(0052334c), wo(poi(0052334c)), wo(poi(0052334c)+2), by(00523f54); } .else { .printf \"MINIMAP_INIT left=%d top=%d width=%d height=%d right=%d bottom=%d backing=00000000 backing_sz=(0,0) scale=%d\\n\", wo(00523344), wo(00523346), wo(00523348), wo(0052334a), wo(00523344)+wo(00523348)-1, wo(00523346)+wo(0052334a)-1, by(00523f54); }; gc"

bp 00418700 ".if (@$t14 != 0) { .if (poi(005202e0) != 0) { .printf \"MINIMAP_SURFACE_SAMPLE redraw=%d left=%d top=%d width=%d height=%d right=%d bottom=%d backing=%p d5202e0=%p map_sz=(%d,%d) samples=(%02x,%02x,%02x,%02x,%02x,%02x)\\n\", @$t13, wo(00523344), wo(00523346), wo(00523348), wo(0052334a), wo(00523344)+wo(00523348)-1, wo(00523346)+wo(0052334a)-1, poi(0052334c), poi(005202e0), wo(poi(005202e0)), wo(poi(005202e0)+2), by(poi(poi(005202e0)+4)+0n24*wo(poi(005202e0))+0n594), by(poi(poi(005202e0)+4)+0n80*wo(poi(005202e0))+0n672), by(poi(poi(005202e0)+4)+0n144*wo(poi(005202e0))+0n736), by(poi(poi(005202e0)+4)+0n208*wo(poi(005202e0))+0n780), by(poi(poi(005202e0)+4)+0n240*wo(poi(005202e0))+0n672), by(poi(poi(005202e0)+4)+0n528*wo(poi(005202e0))+0n736); }; }; gc"

bp 0040D560 ".if (@$t14 != 0) { .printf \"MINIMAP_DIRTY_ENTRY ret=%p left=%d top=%d width=%d height=%d right=%d bottom=%d backing=%p ax=%x bx=%x cx=%x dx=%x\\n\", poi(@esp), wo(00523344), wo(00523346), wo(00523348), wo(0052334a), wo(00523344)+wo(00523348)-1, wo(00523346)+wo(0052334a)-1, poi(0052334c), @ax, @bx, @cx, @dx; }; gc"
