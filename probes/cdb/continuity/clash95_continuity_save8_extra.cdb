.echo === Clash95 continuity roundtrip extra: force saveGame slot 8 on the world map ===
.echo Harness-only continuity probe: run with -LoadSlot 7 so the game's own
.echo natural load-menu route reads back save 7.dat, then force one saveGame
.echo call for slot 8. Byte-identical 7.dat and 8.dat prove a save-load-save
.echo roundtrip with no state drift.
.echo State flag lives at 00400040 in the DOS stub - never read at runtime -
.echo because the base template already consumes every t0-t19 pseudo-register.
ed 00400040 0
bp 0040B0C3 ".if (poi(00400040) == 0) { ed 00400040 1; .printf \"CONTINUITY_SAVE_CALL slot=8 gd=%p surface=%p size=(%d,%d)\\n\", poi(005202e4), poi(005202e0), wo(poi(005202e0)), wo(poi(005202e0)+2); r esp=@esp-4; ed @esp 0040B0C3; r eax=8; r edx=00543d28; r eip=004443E0; } .else { .if (poi(00400040) == 1) { ed 00400040 2; .printf \"CONTINUITY_SAVE_RETURNED slot=8 eax=%d gd=%p\\n\", @eax, poi(005202e4); }; }; gc"
