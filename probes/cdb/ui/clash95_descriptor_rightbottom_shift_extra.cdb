.echo === Clash95 descriptor right-bottom shift experiment ===
.echo CDB-only runtime shift for dword_511D40 command descriptors by +160,+120

bp 0040A400 ".if (@$t14 != 0) { .printf \"DESCRB_SHIFT_BEFORE ret=%p d511d40=(%d,%d) e1=(%d,%d) e2=(%d,%d) e3=(%d,%d) e4=(%d,%d) e5=(%d,%d) render=%p map_surface=%p sz=(%d,%d) clip_old=%08x\\n\", poi(@esp), poi(00511d40), poi(00511d44), poi(00511d75), poi(00511d79), poi(00511daa), poi(00511dae), poi(00511ddf), poi(00511de3), poi(00511e14), poi(00511e18), poi(00511e49), poi(00511e4d), poi(00511230), poi(005202e0), wo(poi(005202e0)), wo(poi(005202e0)+2), poi(00419d8e); ed 00419d8e 00000320; ed 00511d40 0n576; ed 00511d44 0n520; ed 00511d75 0n640; ed 00511d79 0n520; ed 00511daa 0n704; ed 00511dae 0n520; ed 00511ddf 0n576; ed 00511de3 0n552; ed 00511e14 0n640; ed 00511e18 0n552; ed 00511e49 0n704; ed 00511e4d 0n552; .printf \"DESCRB_SHIFT_AFTER d511d40=(%d,%d) e1=(%d,%d) e2=(%d,%d) e3=(%d,%d) e4=(%d,%d) e5=(%d,%d) clip_new=%08x\\n\", poi(00511d40), poi(00511d44), poi(00511d75), poi(00511d79), poi(00511daa), poi(00511dae), poi(00511ddf), poi(00511de3), poi(00511e14), poi(00511e18), poi(00511e49), poi(00511e4d), poi(00419d8e); }; gc"
bp 00419D80 ".if (@$t14 != 0) { .printf \"DESCRB_419D80_ENTRY ret=%p list=%p first=(%d,%d) render=%p map_surface=%p sz=(%d,%d)\\n\", poi(@esp), @eax, poi(@eax), poi(@eax+4), poi(00511230), poi(005202e0), wo(poi(005202e0)), wo(poi(005202e0)+2); }; gc"
bp 00419DA7 ".if (@$t14 != 0) { .printf \"DESCRB_DRAW ptr=%p x=%d y=%d flags=0x%02x draw=%p hit=%p render=%p map_surface=%p is511d40=%d\\n\", @ecx, poi(@ecx), poi(@ecx+4), by(@ecx+8), poi(@ecx+0n28), poi(@ecx+0n32), poi(00511230), poi(005202e0), ((@ecx >= 00511d40) & (@ecx < 00511e80)); }; gc"
