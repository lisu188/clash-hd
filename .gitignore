# OS/editor junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# Python temporary files
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Logs and temporary output
*.log
*.tmp
*.temp
tmp/
temp/

# Local game binaries and patched executable artifacts.
# Keep proprietary executables out of this repository; build/test candidates in
# C:\Clash or isolated C:\ClashTests folders instead.
/*.exe
*.exe
*.dll
*.obj
*.dmp
*.dump
*.pml
*.raw
*.iso
*.cue
*.bin
*.sav
*.sg
*.dat

# Obsidian local workspace/cache files. Markdown notes are not ignored.
.obsidian/workspace*
.obsidian/cache/
.trash/

# Codex/Claude local state
.codex
.codex-loop/
.agents/
.claude/

# Optional generated archive form of cloud fixtures. The searchable fixture tree
# under cloud/fixtures/ is the committed source of truth.
cloud/*.zip
!cloud/fixtures/**/*.log

# Evidence exceptions: the repo-only refresh parses these small run logs and
# raw hit/record dumps. Keep them tracked so evidence survives workspace moves
# (the 2026-07-12 move lost every untracked archive log and forced a full
# hidden-run regeneration campaign).
!captures/archive/cdb-surface-dump-*/cdb-surface-dump.log
!captures/archive/battle-visible-input-*/cdb-visible-input.log

# Local-only Codex loop credentials/secrets. Keep VM passwords out of git.
.codex-loop/*.local.*
.codex-loop/*credential*
.codex-loop/*secret*
.codex-loop/tmp-tests/
.codex-loop/tmp-tests-probe/
captures/tmp-tests-probe/
